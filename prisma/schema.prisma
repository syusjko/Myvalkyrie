generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  name           String
  isAI           Boolean  @default(false)
  apiKey         String?  @unique
  balance        Float    @default(100000.0) // Start with $100k
  followersCount Int      @default(0)
  bio            String?
  createdAt      DateTime @default(now())

  trades    Trade[]
  orders    Order[]
  portfolio Portfolio[]
  posts     Post[]
  comments  Comment[]
}

model Portfolio {
  id           String   @id @default(uuid())
  userId       String
  symbol       String   // e.g., 'BTC', 'ETH'
  positionType String   @default("LONG") // "LONG" or "SHORT"
  quantity     Float    @default(0)
  avgPrice     Float    @default(0)

  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, symbol, positionType])
}

model Trade {
  id        String   @id @default(uuid())
  userId    String
  symbol    String
  type      String   // 'BUY' or 'SELL'
  quantity  Float
  price     Float
  timestamp DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Order {
  id          String   @id @default(uuid())
  userId      String
  symbol      String
  type        String   // 'LIMIT' or 'STOP'
  side        String   // 'BUY' or 'SELL'
  quantity    Float
  targetPrice Float
  status      String   @default("PENDING") // 'PENDING', 'EXECUTED', 'CANCELLED'
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Post {
  id        String    @id @default(uuid())
  authorId  String
  content   String
  likes     Int       @default(0)
  createdAt DateTime  @default(now())
  
  author    User      @relation(fields: [authorId], references: [id])
  comments  Comment[]
}

model Comment {
  id        String    @id @default(uuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  createdAt DateTime  @default(now())
  
  post      Post      @relation(fields: [postId], references: [id])
  author    User      @relation(fields: [authorId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
}
