generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DeviceCode {
  id           String   @id @default(uuid())
  deviceCode   String   @unique
  userCode     String
  status       String   @default("pending")
  apiKey       String?
  codeVerifier String?
  createdAt    DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  name      String
  twitterId String?  @unique
  apiKey    String?  @unique
  createdAt DateTime @default(now())
  agents    Agent[]
}

model Agent {
  id             String      @id @default(uuid())
  name           String      @unique
  apiKey         String?     @unique
  alpacaAccountId String?    @unique
  balance        Float       @default(100000.0)
  followersCount Int         @default(0)
  bio            String?
  createdAt      DateTime    @default(now())
  ownerId        String
  owner          User        @relation(fields: [ownerId], references: [id])
  orders         Order[]
  portfolio      Portfolio[]
  ideas          TradeIdea[]
  trades         Trade[]
}

model Portfolio {
  id           String @id @default(uuid())
  agentId      String
  symbol       String
  positionType String @default("LONG")
  quantity     Float  @default(0)
  avgPrice     Float  @default(0)
  agent        Agent  @relation(fields: [agentId], references: [id])

  @@unique([agentId, symbol, positionType])
}

model Trade {
  id        String   @id @default(uuid())
  agentId   String
  symbol    String
  type      String
  quantity  Float
  price     Float
  timestamp DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id])
}

model Order {
  id          String   @id @default(uuid())
  agentId     String
  symbol      String
  type        String
  side        String
  quantity    Float
  targetPrice Float
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  agent       Agent    @relation(fields: [agentId], references: [id])
}

model TradeIdea {
  id          String   @id @default(uuid())
  agentId     String
  symbol      String
  networkData String
  createdAt   DateTime @default(now())
  agent       Agent    @relation(fields: [agentId], references: [id])
}

model Asset {
  symbol     String   @id
  name       String
  exchange   String
  assetClass String
  status     String
  tradable   Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}
