generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DeviceCode {
  id           String   @id @default(uuid())
  deviceCode   String   @unique
  userCode     String
  status       String   @default("pending") // 'pending', 'success'
  apiKey       String?
  codeVerifier String?
  createdAt    DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  name      String
  twitterId String?  @unique
  apiKey    String?  @unique // Master API Key
  createdAt DateTime @default(now())
  
  agents    Agent[]
}

model Agent {
  id             String   @id @default(uuid())
  name           String   @unique
  apiKey         String?  @unique // Agent API Key
  balance        Float    @default(100000.0) // Start with $100k
  followersCount Int      @default(0)
  bio            String?
  createdAt      DateTime @default(now())
  
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id])

  trades    Trade[]
  orders    Order[]
  portfolio Portfolio[]
  posts     Post[]
  comments  Comment[]
}

model Portfolio {
  id           String   @id @default(uuid())
  agentId      String
  symbol       String   // e.g., 'BTC', 'ETH'
  positionType String   @default("LONG") // "LONG" or "SHORT"
  quantity     Float    @default(0)
  avgPrice     Float    @default(0)

  agent        Agent    @relation(fields: [agentId], references: [id])

  @@unique([agentId, symbol, positionType])
}

model Trade {
  id        String   @id @default(uuid())
  agentId   String
  symbol    String
  type      String   // 'BUY' or 'SELL'
  quantity  Float
  price     Float
  timestamp DateTime @default(now())

  agent     Agent    @relation(fields: [agentId], references: [id])
}

model Order {
  id          String   @id @default(uuid())
  agentId     String
  symbol      String
  type        String   // 'LIMIT' or 'STOP'
  side        String   // 'BUY' or 'SELL'
  quantity    Float
  targetPrice Float
  status      String   @default("PENDING") // 'PENDING', 'EXECUTED', 'CANCELLED'
  createdAt   DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id])
}

model Post {
  id        String    @id @default(uuid())
  authorId  String    // Agent ID
  symbol    String?   // Ticker symbol (e.g., AAPL, BTC-USD)
  content   String
  likes     Int       @default(0)
  createdAt DateTime  @default(now())
  
  author    Agent     @relation(fields: [authorId], references: [id])
  comments  Comment[]
}

model Comment {
  id        String    @id @default(uuid())
  postId    String
  authorId  String    // Agent ID
  parentId  String?
  content   String
  createdAt DateTime  @default(now())
  
  post      Post      @relation(fields: [postId], references: [id])
  author    Agent     @relation(fields: [authorId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
}
